{
  "layer": "top",
  "position": "top",
  "height": 34,
  "spacing": 7,
  "margin-left": 20,
  "margin-right": 20,
  "margin-top": 2,
  "modules-left": [
    "group/hypr",
  ],
  "modules-center": [
      "group/audiogroup",
  ],
  "modules-right": [
    "custom/waypaper",
    "group/hardware",
    "tray",
    "custom/mako",
    "custom/clipboard",
    "group/clockgroup"
  ],
  "group/clockgroup": {
    "orientation": "horizontal",
    "modules": [
      "clock#date", "custom/separator", "clock"
    ]
  },


  "group/hypr": {
    "orientation": "horizontal",
    "modules": [
        "custom/powermenu",
        "custom/separator",

      "hyprland/workspaces",
      "custom/separator",
      "custom/active-window"
    ]
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "\uf111",
      "default": "\uf4aa"
    },

    "persistent-workspaces": {
      "*": 4
    }
  },
  "custom/active-window": {
    "exec": "bash ~/.config/waybar/scripts/active-window.sh",
    "restart-interval": 1,
    "max-length": 40,
    "tooltip": false,
    "exec-on-event": false,
    "align": 0
  },
  "cpu": {
    "interval": 10,
    "format": "\uf2db  {usage}%",
    "max-length": 10
  },
  "memory": {
    "interval": 10,
    "format": "\uefc5  {}%"
  },
  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "format": "\uf2c7 {temperatureC}\u00b0C",
    "on-click": "psensor"
  },
  "custom/separator": {
    "format": "|",
    "tooltip": false
  },
  "group/audiogroup": {
    "orientation": "horizontal",
    "modules": [
      "mpris",
      "custom/separator",
      "pulseaudio",
    ]
  },
  "group/hardware": {
    "orientation": "horizontal",
    "modules": [
      "cpu",
      "custom/separator",
      "memory",
      "custom/separator",
      "temperature"
    ]
  },
  "custom/waypaper": {
    "format": "\udb83\ude09",
    "tooltip-format": "Wallpaper",
    "on-click": "bash ~/.config/waybar/scripts/waypaper.sh"
  },
  "custom/clipboard": {
    "format": "\udb80\udd4c",
    "tooltip-format": "Walker clipboard",
    "on-click": "walker --provider clipboard"
  },
  "custom/mako": {
    "exec": "bash ~/.config/waybar/scripts/mako.sh",
    "format": "{}",
    "on-click": "bash ~/.config/waybar/scripts/mako-dnd.sh",
    "on-click-right": "bash ~/.config/waybar/scripts/mako-clear.sh",
    "restart-interval": 1,
    "tooltip": false
  },
  "tray": {
    "spacing": 20,
    "icon-size": 16,
    "icons": {
      "blueman": "bluetooth-symbolic",
      "nm-applet": "network-wireless-symbolic",
      "udiskie": "drive-removable-media-usb-symbolic",
      "steam": "com.valvesoftware.Steam"
    }
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}\uf294 {volume}% {format_source}",
    "format-bluetooth-muted": "\uf6a9 {icon}\uf294 {format_source}",
    "format-muted": "\ufa80",
    "format-icons": {
      "headphone": "\uf025",
      "hands-free": "\uf590",
      "headset": "\uf590",
      "phone": "\uf095",
      "portable": "\uf095",
      "car": "\uf1b9",
      "default": [
        "\uf026",
        "\uf027",
        "\uf028"
      ]
    },
    "on-click-right": "pavucontrol",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip": false
  },
  "clock#date": {
    "format": "{:%a %d %b}",
    "tooltip": false
  },
  "custom/powermenu": {
    "format": "\uf011",
    "on-click": "walker --provider menus:powermenu",
    "tooltip": false
  },
  "mpris": {
    "format": "{status_icon}",
    "title-len": 20,
    "dynamic-len": 40,
    "player-icons": {
      "default": "\uf04c ",
    },
    "status-icons": {
      "paused": "\uf04b",
      "default": "\uf04c"
    },
  },
}
