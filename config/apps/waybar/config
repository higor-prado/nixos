{
  "layer": "top",
  "position": "top",
  "height": 16,
  "spacing": 7,
  "margin-left": 8,
  "margin-right": 8,
  "margin-top": 8,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": [ "clock"],
  "modules-right": ["cpu", "memory", "temperature", "custom/waypaper", "tray", "network", "pulseaudio", "custom/dunst", "custom/powermenu"],


  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
    }
  },

  "cpu": {
    "interval": 10,
    "format": "  {usage}%",
    "max-length": 10
  },


  "memory": {
    "interval": 10,
    "format": "  {}%"
  },


  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "format": " {temperatureC}°C",
    "on-click": "psensor"
  },

  "custom/waypaper": {
      "format": "󰸉",
      "tooltip-format": "Wallpaper",
      "on-click": "bash ~/.config/waybar/scripts/waypaper.sh"
  },

  "custom/dunst": {
      "exec": "bash ~/.config/waybar/scripts/dunst.sh",
      "format": "{}",
      "on-click": "dunstctl set-paused toggle",
      "restart-interval": 1,
      "tooltip": false
  },

  "tray": {
      "spacing": 20,
  },

  "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{icon} {volume}% {format_source}",
      "format-bluetooth-muted": " {icon} {format_source}",
      "format-muted": "婢",
      "format-icons": {
          "headphone": "",
          "hands-free": "",
          "headset": "",
          "phone": "",
          "portable": "",
          "car": "",
          "default": ["", "", ""]
      },
      "on-click-right": "pavucontrol",
	    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "network": {
      "format-wifi": "直  {signalStrength}%",
      "format-ethernet": " wired",
      "format-disconnected": "睊 ",
      "on-click": "sh ~/.config/wofi/wifimenu.sh"
  },

  "clock": {
      "format-alt": "<span> </span> {:%a %b %d}",
      "format": "<span> </span> {:%H:%M}"
  },

  "custom/powermenu": {
      "format": "",
      "on-click": "bash ~/.config/rofi/powermenu/type-2/powermenu.sh",
  }
}
