{
  "layer": "top",
  "position": "top",
  "height": 16,
  "spacing": 7,
  "margin-left": 8,
  "margin-right": 8,
  "margin-top": 8,

  "modules-left": ["group/hypr"],
  "modules-center": ["clock"],
  "modules-right": ["custom/waypaper", "group/hardware", "tray", "pulseaudio", "custom/mako", "custom/clipboard", "custom/powermenu"],

  "group/hypr": {
    "orientation": "horizontal",
    "modules": ["hyprland/workspaces", "custom/active-window"]
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 4
    }
  },

  "custom/active-window": {
    "exec": "bash ~/.config/waybar/scripts/active-window.sh",
    "restart-interval": 1,
    "max-length": 25,
    "tooltip": false,
    "exec-on-event": false,
    "align": 0
  },

  "cpu": {
    "interval": 10,
    "format": "  {usage}%",
    "max-length": 10
  },

  "memory": {
    "interval": 10,
    "format": "  {}%"
  },

  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "format": " {temperatureC}°C",
    "on-click": "psensor"
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["cpu", "custom/separator", "memory", "custom/separator", "temperature"]
  },

  "custom/waypaper": {
    "format": "󰸉",
    "tooltip-format": "Wallpaper",
    "on-click": "bash ~/.config/waybar/scripts/waypaper.sh"
  },

  "custom/clipboard": {
    "format": "󰅌",
    "tooltip-format": "Clipboard history",
    "on-click": "bash ~/.config/waybar/scripts/clipboard-history.sh"
  },

  "custom/mako": {
    "exec": "bash ~/.config/waybar/scripts/mako.sh",
    "format": "{}",
    "on-click": "bash ~/.config/waybar/scripts/mako-dnd.sh",
    "on-click-right": "bash ~/.config/waybar/scripts/mako-clear.sh",
    "restart-interval": 1,
    "tooltip": false
  },

  "tray": {
    "spacing": 20,
    "icon-size": 16,
    "icons": {
      "blueman": "bluetooth-symbolic",
      "nm-applet": "network-wireless-symbolic",
      "udiskie": "drive-removable-media-usb-symbolic"
    }
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon} {volume}% {format_source}",
    "format-bluetooth-muted": " {icon} {format_source}",
    "format-muted": "婢",
    "format-icons": {
      "headphone": "",
      "hands-free": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": ["", "", ""]
    },
    "on-click-right": "pavucontrol",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "clock": {
    "format-alt": "<span> </span> {:%a %b %d}",
    "format": "<span> </span> {:%H:%M}",
    "tooltip": false
  },

  "custom/powermenu": {
    "format": "",
    "on-click": "bash ~/.config/rofi/powermenu/type-2/powermenu.sh",
    "tooltip": false
  }
}
