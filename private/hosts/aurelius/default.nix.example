# Copy to ./default.nix (untracked) and adjust with Aurelius-specific access policy.
{ config, ... }:
let
  userName = "your-user";
in
{
  imports = [
    ./networking.nix
    ./services.nix
  ];

  users.users.${userName}.openssh.authorizedKeys.keys = [
    "ssh-ed25519 AAAA... replace-with-real-key"
  ];

  security.sudo.extraRules = [
    {
      users = [ userName ];
      commands = [
        {
          command = "/run/current-system/sw/bin/nix";
          options = [ "NOPASSWD" ];
        }
        {
          command = "/nix/store/*/bin/nix";
          options = [ "NOPASSWD" ];
        }
        {
          command = "/nix/var/nix/profiles/system/bin/switch-to-configuration";
          options = [ "NOPASSWD" ];
        }
        {
          command = "/nix/store/*/bin/switch-to-configuration";
          options = [ "NOPASSWD" ];
        }
      ];
    }
  ];
}
